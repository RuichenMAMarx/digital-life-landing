PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
TG_BOT_USERNAME=splandour_550w_bot
CONTROL_PLANE_KEY=replace-with-a-strong-random-secret
# payment gate
# true: only paid/waived orders can handoff
# false: disable payment check for handoff
REQUIRE_PAYMENT_FOR_HANDOFF=true
# comma-separated free plan types that auto-mark as waived
FREE_PLAN_TYPES=trial,demo
# Stripe webhook (payment callback)
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_REQUIRE_SIGNATURE=true
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
# json (default) or postgres
STORAGE_DRIVER=json
# required when STORAGE_DRIVER=postgres
DATABASE_URL=
# disable or require
DATABASE_SSL=disable
CONTROL_PLANE_DATA_DIR=./data
CHANNEL_POOL_FILE=./data/channel-pool.json
# Runtime orchestrator (Yaya instantiation)
# none (default) | webhook
RUNTIME_ORCHESTRATOR_MODE=none
RUNTIME_ORCHESTRATOR_URL=
RUNTIME_ORCHESTRATOR_KEY=
RUNTIME_ORCHESTRATOR_TIMEOUT_MS=20000
