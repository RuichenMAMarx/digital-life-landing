TELEGRAM_BOT_TOKEN=your_bot_token
MIN_AUDIO_SECONDS=10
BOT_DATA_DIR=./data
# Preferred dedicated channel kinds in control-plane, comma separated
PREFERRED_CHANNEL_KINDS=telegram,whatsapp
# Optional: control-plane service (recommended)
CONTROL_PLANE_BASE_URL=http://localhost:8787
CONTROL_PLANE_KEY=replace-with-the-same-key-as-control-plane
# Runtime init polling
RUNTIME_POLL_INTERVAL_MS=6000
RUNTIME_POLL_MAX_ATTEMPTS=25
# Reply pacing (first sentence: no delay; later replies: 1x typing speed)
ENABLE_TYPING_DELAY=true
TYPING_CPS=6
TYPING_MIN_DELAY_MS=1200
TYPING_MAX_DELAY_MS=7000
# Optional: when set, bot will POST onboarding payload here after assets are ready
ORCHESTRATOR_WEBHOOK_URL=
